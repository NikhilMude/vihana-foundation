            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nikhil Mude\",\n  \"email\": \"nikhil@example.com\",\n  \"phone\": \"9876543210\",\n  \"interest\": \"Volunteer\",\n  \"message\": \"I would like to help with weekend activities.\",\n  \"company\": \"\"\n}"
